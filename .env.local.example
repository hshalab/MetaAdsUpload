# Meta API
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=               # Retrieved via OAuth flow
META_AD_ACCOUNT_ID=              # Selected per connection
META_PAGE_ID=                    # Selected per connection
META_PIXEL_ID=                   # Optional

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Auth (NextAuth)
AUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Seed (one-time admin setup, then remove)
SEED_SECRET=a-random-secret-for-initial-setup
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe123!

# Cloudflare R2 (Video Storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=editor-uploads
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Google Drive (Service Account for creative browsing)
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com"}'
GOOGLE_DRIVE_ROOT_FOLDER=your_google_drive_folder_id

# Cron (Vercel Cron or external)
CRON_SECRET=your-cron-secret

# WhatsApp notifications (optional — silent no-op until set)
WHATSAPP_ACCESS_TOKEN=       # System User token with whatsapp_business_messaging
WHATSAPP_PHONE_NUMBER_ID=    # Sender phone number ID from WhatsApp Manager
WHATSAPP_ADMIN_PHONE=        # E.164 number for admin notifications, e.g. +467xxxxxxxx

# Registration invite gate (required in production)
REGISTRATION_INVITE_CODE=    # share with new editors; registration is closed in prod without it
